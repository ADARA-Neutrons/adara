# Locate the "Last" ADARA Output Stream File for the *Source* Run...

index=1

echo -e -n "\nLocating Last Data File "
echo "for Source Run ${SourceRun}."
src_datafile=`${LS} "${SourceDir}" \
	| ${GREP} -E \
		--regexp "^m[0-9]+-f[0-9]+-run-${SourceRun}.adara$" \
		--regexp "^f[0-9]+-run-${SourceRun}.adara$" \
	| ${TAIL} -${index} | ${HEAD} -1`
ckdatafile=$?

if [[ ${ckdatafile} != 0 ]]; then
	echo -e -n "\nERROR Locating Last "
	echo "ADARA Output Stream File for Source Run ${SourceRun}!"
	echo -e "\nBailing..."
	exit 98
fi

echo -e "\nFound Last ADARA Output Stream File for Source Run ${SourceRun}:"
echo -e "\t[${src_datafile}]"

# Determine Device ID for IPTS-ITEMS PV Logs...

echo
${ADARA_PARSER} --showddp "${SourceDir}/${src_datafile}" \
	| ${GREP} -B 6 "IPTS"

DEVICE=`${ADARA_PARSER} --showddp "${SourceDir}/${src_datafile}" \
	| ${GREP} -B 6 "IPTS" | grep "Device " | ${AWK} '{print $2}'`

echo -e -n "\nIPTS-ITEMS Device Extracted from Raw Data Stream Files as:"
echo -e " [${DEVICE}]"
CHECK_PROCEED

# Extract Raw Data File with ITEMS Sample Meta-Data PV Value Updates...

echo -e "\nExtracting Raw Data File with Sample Meta-Data..."

${ADARA_MUNGE} "${SourceDir}/${src_datafile}" \
	--savefile "m00000001-f00000002-add00000001-run-XXXXXX.adara" \
	--savepkts 8388864 --savepkts 8389120 --savepkts 8389376 \
	--deviceid ${DEVICE} 1>/dev/null 2>munge.out

${Less} +"/Save Packet" munge.out

${ADARA_PARSER} --showddp \
	m00000001-f00000002-add00000001-run-XXXXXX.adara | ${Less}

${RM} munge.out

CHECK_PROCEED

echo -e "\nSaving ITEMS Sample Meta-Data Raw Data Addendum File to \$HOME:"

${MV} m00000001-f00000002-add00000001-run-XXXXXX.adara \
	~/${ITEMS_NEW}.m00000001-f00000002-add00000001-run-XXXXXX.adara

echo
${LS} -l ~/${ITEMS_NEW}.m00000001-f00000002-add00000001-run-XXXXXX.adara

CHECK_PROCEED

#
# Process Each Run Number in Turn...
#

for run in ${RUN_NUMBERS} ; do

	echo -e "\nProcessing Run Number: ${run}"

	#
	# Find the SMS Raw Data Files for This Run...! ;-D
	#

	rundir=`${LS} -d ${SMS_DATA}/*/*-run-${run} 2>&1`
	ckrundir=$?

	if [[ ${ckrundir} != 0 ]]; then
		echo -e "\nERROR Locating SMS Raw Data Directory for Run ${run}!"
		CHECK_PROCEED
		echo -e "\nContinuing with Next Run Number..."
		continue
	fi

	echo -e "\nFound SMS Raw Data Directory for Run ${run}:\n\t[${rundir}]"

	${LS} -lt "${rundir}" | ${HEAD} -n 20

	CHECK_PROCEED

	#
	# Locate Last ADARA Output Stream File for Run...
	#

	index=1

	echo -e "\nLocating Last Data File for Run ${run}."
	datafile=`${LS} "${rundir}" \
		| ${GREP} -E \
			--regexp "^m[0-9]+-f[0-9]+-run-${run}.adara$" \
			--regexp "^f[0-9]+-run-${run}.adara$" \
		| ${TAIL} -${index} | ${HEAD} -1`
	ckdatafile=$?

	if [[ ${ckdatafile} != 0 ]]; then
		echo -e -n "\nERROR Locating Last "
		echo "ADARA Output Stream File for Run ${run}!"
		CHECK_PROCEED
		echo -e "\nContinuing with Next Run Number..."
		continue
	fi

	# Make Sure We Only Got *1* Data File...! ;-D
	ckone=`echo "${datafile}" | ${WC} | ${AWK} '{print $1}'`

	if [[ ${ckone} != 1 ]]; then
		echo -e -n "\nERROR: Multiple Output Stream Files Found "
		echo "for Run ${run}!"
		echo -e "\n${datafile}\n"
		CHECK_PROCEED
		echo -e "\nContinuing with Next Run Number..."
		continue
	fi

	echo -e -n "\nFound Last ADARA Output Stream File for Run ${run}:"
	echo -e "\t[${datafile}]"

	CHECK_PROCEED

	# Snag the IPTS Proposal from This Raw Data File...

	IPTS=`${GREP} --text "proposal_id" "${rundir}/${datafile}" \
		| ${AWK} -F "[<>]" '{print $3}'`

	ckipts=$?

	if [[ ${ckipts} != 0 ]]; then
		echo -e -n "\nERROR Extracting IPTS Proposal "
		echo "from Stream File for Run ${run}!"
		echo -e "\n\t[${IPTS}]"
		### Try the "2nd" or "Next to Last" File... (Increase Index)
		CHECK_PROCEED \
			"Do You Want To Increment The File Index and Retry"
		_ckincrindex=$?
		if [[ ${_ckincrindex} != 0 ]]; then
			echo -e "\nContinuing with Next Run Number..."
			continue
		fi
	else
		echo -e "\nFound IPTS Proposal in Stream File: [${IPTS}]"
	fi

	CHECK_PROCEED

	#
	# Fix ITEMS Sample ID Meta-Data...! ;-D
	#

	cd ${rundir}

	# Extract Mode Index and File Index from Raw Data File Name...

	mode=`echo "${datafile}" | ${AWK} -F "[-]" '{print $1}'`

	fileNo=`echo "${datafile}" | ${AWK} -F "[mf-]" '{printf("%d", $4)}'`

	flast=`echo "${fileNo}" | ${AWK} '{printf("f%08d", $1)}'`

	flast_plus_1=`echo "$(( ${fileNo} + 1 ))" \
		| ${AWK} '{printf("f%08d", $1)}'`

	flast_plus_2=`echo "$(( ${fileNo} + 2 ))" \
		| ${AWK} '{printf("f%08d", $1)}'`

	# Install New ITEMS Sample Meta-Data Addendum File as "Last + 1" File

	echo -e "\nInstalling ITEMS Sample Meta-Data Addendum as Last + 1 File:"
	echo -e "\t${mode}-${flast_plus_1}-run-${run}.adara"

	${CP} ~/${ITEMS_NEW}.m00000001-f00000002-add00000001-run-XXXXXX.adara .

	${MV} ${ITEMS_NEW}.m00000001-f00000002-add00000001-run-XXXXXX.adara \
		${mode}-${flast_plus_1}-run-${run}.adara

	CHECK_PROCEED

	# Extract Run End Packet from Last into "Last + 2" File

	echo -e "\nExtract Run End Packet from Last into Last + 2 File:"
	echo -e "\t${mode}-${flast_plus_2}-run-${run}.adara"

	${ADARA_MUNGE} ${mode}-${flast}-run-${run}.adara \
		--savefile ${mode}-${flast_plus_2}-run-${run}.adara \
		--savestop 1>/dev/null 2>munge.out
	
	${Less} +"/Saving Run Stop Packet" munge.out

	echo -e "\nNew Last Raw Data File (Last + 2):"
	echo -e "\t${mode}-${flast_plus_2}-run-${run}.adara"
	echo

	${ADARA_PARSER} ${mode}-${flast_plus_2}-run-${run}.adara

	${RM} munge.out

	CHECK_PROCEED

	# Backup and Strip Run End from Last Raw Data File...

	echo -e "\nBackup and Strip Run End from Last Raw Data File:"
	echo -e "\t${mode}-${flast}-run-${run}.adara"

	${MV} ${mode}-${flast}-run-${run}.adara \
		${mode}-${flast}-run-${run}.adara.BACKUP-$$

	${ADARA_MUNGE} \
		${mode}-${flast}-run-${run}.adara.BACKUP-$$ \
		--skipstop 1>${mode}-${flast}-run-${run}.adara \
		2>munge.out
	
	${Less} +"/Skipping Run Stop Packet" munge.out

	echo -e "\nBefore:\n"

	${ADARA_PARSER} ${mode}-${flast}-run-${run}.adara.BACKUP-$$ \
		| tail -20

	echo -e "\nAfter:\n"

	${ADARA_PARSER} ${mode}-${flast}-run-${run}.adara \
		| tail -20

	${RM} munge.out

	CHECK_PROCEED \
		"Do You Want To Submit the Run Directory for ReScan...?"
	_ckresubmit=$?

	if [[ ${_ckresubmit} == 0 ]]; then

		### Save Copy of Original NeXus as *.ORIG...

		echo -e "\nPlease Save a Copy of Original NeXus as *.ORIG..."

		_nexus="nexus/${INST}_${run}.nxs.h5"

		echo -e "\n${MV} ${ARCHIVE}/${IPTS}/${_nexus} \\"
		echo -e "\t${ARCHIVE}/${IPTS}/${_nexus}.ORIG"

		CHECK_PROCEED
		_cksubmit=$?

		if [[ ${_cksubmit} == 0 ]]; then

			# RescanRunDir Approach...

			# ${RM} translation_completed

			# caput -S ${BL}:SMS:StorageManager:RescanRunDir `pwd` ; smslog

			# ${LS} -l

			# Re-Submit Modified Run for Translation to NeXus...
			RESUBMIT_RUN "${rundir}"

			# Check Resulting NeXus Data File...

			# echo -e "\nFrom archive-accessible host, please check:"

			# echo -e "\nls -l ${ARCHIVE}/${IPTS}/${_nexus}"

			# echo -e "\nnxls ${ARCHIVE}/${IPTS}/${_nexus} \\"
			# echo -e "    -p /entry/sample -v -l"

			CHECK_PROCEED
		fi

	fi

done

#
# Done
#

echo -e "\nDone.\n"


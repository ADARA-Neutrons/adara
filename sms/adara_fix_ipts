#!/bin/bash
#
# ADARA "Fix IPTS" Script...! ;-D
#
# Script to Automate Changing the IPTS Proposal Number for Run(s)
# and Resubmitting Them Through the STS to Re-Catalog...! ;-D
#
# (Because it can happen that often... ;-)
#

SMS_DATA="/SNSlocal/sms/data"

STS1="sns-sts1.sns.gov"
STS2="sns-sts2.sns.gov"

USAGE()
{
	echo -e "\nusage: adara_fix_ipts \\"
	echo "         [--sts1|--sts2] [--sts|--sts_test|--sts_dummy] \\"
	echo "         [--sms_data=<${SMS_DATA}>] \\"
	echo "         [--run=<RunNumber1>] \\"
	echo "         [--run=<RunNumber2,RunNumber3,...>] \\"
	echo "         [--run=<RunNumber4-RunNumber5>] \\"
	echo "         [--ipts=<IPTS-nnnnn>] [--help]"
	echo
}

PARSE_RUN_NUMBERS()
{
	local _runlist="$1"

	# Strip Off Any Comma Separators...
	_runlist=`echo "${_runlist}" | sed 's/,/ /g'`

	# Step Through Run Numbers Looking for Any Run Number Ranges
	local _runlistall
	local _run
	for _run in ${_runlist} ; do
		# Run Number Range
		if [[ "${_run}" =~ - ]]; then
			local _start
			local _end
			_start=`echo "${_run}" | awk -F "-" '{print $1}'`
			_end=`echo "${_run}" | awk -F "-" '{print $2}'`
			for (( i = _start ; i <= _end ; ++i )); do
				if [[ -z "${_runlistall}" ]]; then
					_runlistall="$i"
				else
					_runlistall="${_runlistall} $i"
				fi
			done
		# Plain Run Number
		else
			if [[ -z "${_runlistall}" ]]; then
				_runlistall="${_run}"
			else
				_runlistall="${_runlistall} ${_run}"
			fi
		fi
	done

	# Now Append Parsed Run Number List to Overall Run List
	if [[ -z "${RUN_NUMBERS}" ]]; then
		RUN_NUMBERS="${_runlistall}"
	else
		RUN_NUMBERS="${RUN_NUMBERS} ${_runlistall}"
	fi
	echo -e "\nAdding Run Number(s) ${_runlistall} to Run List."
}

CHECK_PROCEED()
{
	local _proceed_ck=""

	echo -e -n "\nProceed (yes/No)? "
	read _proceed_ck

	_proceed_ck=`echo "${_proceed_ck}" | tr '[:upper:]' '[:lower:]'`

	if [[ -z ${_proceed_ck} || ${_proceed_ck} == "n" \
			|| ${_proceed_ck} == "no" ]]; then
		echo -e "\nExiting ADARA Fix IPTS at User's Request.\n"
		exit -99
	fi
}

#
# Parse Command Line Arguments
#

STS_HOST="${STS1}"

STS_SERVICE="sts_dummy"
STS_PORT=""

RUN_NUMBERS=""

IPTS_NEW=""

for arg in "$@" ; do

	key=`echo "$arg" | awk -F = '{print $1}'`
	value=`echo "$arg" | awk -F = '{print $2}'`

	if [[ "#$key#" == '#--sts1#' ]]; then
		STS_HOST="${STS1}"
		echo -e "\nSetting STS Host to: ${STS_HOST}"
	elif [[ "#$key#" == '#--sts2#' ]]; then
		STS_HOST="${STS2}"
		echo -e "\nSetting STS Host to: ${STS_HOST}"
	elif [[ "#$key#" == '#--sts#' ]]; then
		STS_SERVICE="sts"
		echo -e "\nSetting STS Service to: ${STS_SERVICE}"
	elif [[ "#$key#" == '#--sts_test#' ]]; then
		STS_SERVICE="sts_test"
		echo -e "\nSetting STS Service to: ${STS_SERVICE}"
	elif [[ "#$key#" == '#--sts_dummy#' ]]; then
		STS_SERVICE="sts_dummy"
		echo -e "\nSetting STS Service to: ${STS_SERVICE}"
	elif [[ "#$key#" == '#--sms_data#' ]]; then
		SMS_DATA="${value%/}"
		echo -e "\nSetting SMS Data Directory to:\n\t[${SMS_DATA}]"
	elif [[ "#$key#" == '#--run#' ]]; then
		PARSE_RUN_NUMBERS "${value}"
	elif [[ "#$key#" == '#--ipts#' ]]; then
		IPTS_NEW="${value}"
		if [[ ! "${IPTS_NEW}" =~ ^IPTS- ]]; then
			echo -e -n "\n*** WARNING: New Proposal \"${IPTS_NEW}\" "
			echo "Does Not Have the \"IPTS-\" Prefix!"
			CHECK_PROCEED
		fi
		echo -e "\nSetting New IPTS Proposal to: [${IPTS_NEW}]"
	elif [[ "#$key#" == '#--help#' || "#$key#" == '#-h#' ]]; then
		USAGE
		exit 0
	else
		echo -e "\nError: Unknown Command Line Option [${arg}]"
		USAGE
		exit -1
	fi

done

if [[ -z "${RUN_NUMBERS}" ]]; then
	echo -e "\nError: No Run Numbers Specified!"
	USAGE
	exit -2
fi

if [[ -z "${IPTS_NEW}" ]]; then
	echo -e "\nError: No Replacement IPTS Proposal Specified!"
	USAGE
	exit -3
fi

echo -e "\n*** Updating IPTS for Run Numbers:\n\n\t[${RUN_NUMBERS}]\n"
echo "to New Proposal [${IPTS_NEW}]."

echo -e "\nUsing STS \"${STS_SERVICE}\" Service on ${STS_HOST}."

CHECK_PROCEED

#
# Process Each Run Number in Turn...
#

for run in ${RUN_NUMBERS} ; do

	echo -e "\nProcessing Run Number: ${run}"

	#
	# Find the SMS Raw Data Files for This Run...! ;-D
	#

	rundir=`/bin/ls -d ${SMS_DATA}/*/*-run-${run} 2>&1`
	ckrundir=$?

	if [[ $ckrundir != 0 ]]; then
		echo -e "\nERROR Locating SMS Raw Data Directory for Run ${run}!"
		CHECK_PROCEED
		echo -e "\nContinuing with Next Run Number..."
		continue
	fi

	echo -e "\nFound SMS Raw Data Directory for Run ${run}:\n\t[${rundir}]"

	#
	# Locate & Backup the First ADARA Output Stream File for This Run
	#

	datafile=`/bin/ls "${rundir}" | grep -E "^f0+1-run-${run}.adara$"`
	ckdatafile=$?

	if [[ $ckdatafile != 0 ]]; then
		echo -e -n "\nERROR Locating 1st ADARA Output Stream File "
		echo "for Run ${run}!"
		CHECK_PROCEED
		echo -e "\nContinuing with Next Run Number..."
		continue
	fi

	# Make Sure We Only Got *1* Data File...! ;-D
	ckone=`echo "${datafile}" | wc | awk '{print $1}'`

	if [[ ${ckone} != 1 ]]; then
		echo -e -n "\nERROR: Multiple Output Stream Files Found "
		echo -e "for Run ${run}!\n"
		echo -e "${datafile}\n"
		CHECK_PROCEED
		echo -e "\nContinuing with Next Run Number..."
		continue
	fi

	echo -e "\nFound 1st ADARA Output Stream File for Run ${run}:"
	echo -e "\t[${datafile}]"

	# Make a Backup Copy of the Data File Before Proceeding...

	/bin/cp -i "${rundir}/${datafile}" "${rundir}/${datafile}.BACKUP-$$"

	echo -e "\nBackup Up 1st ADARA Output Stream File for Run ${run} to:"
	echo -e "\t[${datafile}.BACKUP-$$]"

	#
	# Determine What the Current IPTS Proposal is for This Run...
	#
	# - Fortunately, the IPTS Proposal is Stored in the RunInfo Packet
	# as Plain Text XML, So We Can Parse and Substitute It "Easily"... ;-D
	#
	# Note: Be Careful to _Avoid_ Things like "IPTS-ITEMS" in the RunInfo!
	# - Better Use the XML Tag "<proposal_id>" instead of plain "IPTS"...
	# - This covers the case where the Original Proposal was _Not_ "IPTS-*".
	#

	ipts_old_line=`grep --text "<proposal_id>" "${rundir}/${datafile}"`
	ckoldiptsline=$?

	if [[ $ckoldiptsline != 0 ]]; then
		echo -e -n "\nERROR Extracting Old Proposal Line from Stream File "
		echo -e "for Run ${run}!\n"
		echo -e "\t[${ipts_old_line}]"
		CHECK_PROCEED
		echo -e "\nContinuing with Next Run Number..."
		continue
	fi

	# Make Sure We Only Got *1* Old Proposal Id Line...! ;-D
	ckoneline=`echo "${ipts_old_line}" | wc | awk '{print $1}'`

	if [[ ${ckoneline} != 1 ]]; then
		echo -e -n "\nERROR: Multiple Proposal Id Lines Found "
		echo -e "for Run ${run}!\n"
		echo -e "${ipts_old_line}\n"
		CHECK_PROCEED
		echo -e "\nContinuing with Next Run Number..."
		continue
	fi

	echo -e "\nFound Old Proposal Id Line for Run ${run}:"
	echo -e "\t[${ipts_old_line}]"

	ipts_old=`echo "${ipts_old_line}" | awk -F "[<>]" '{print $3}'`
	ckoldipts=$?

	if [[ $ckoldipts != 0 ]]; then
		echo -e -n "\nERROR Extracting Old Proposal from Stream File "
		echo "for Run ${run}!"
		CHECK_PROCEED
		echo -e "\nContinuing with Next Run Number..."
		continue
	fi

	echo -e "\nFound Old Proposal Id for Run ${run}: [${ipts_old}]"

	#
	# Compare the *Length* of the Old and New Proposal Ids,
	# to Carefully Determine How We Handle the Substitution
	# Without _Changing the Size_ of the XML Payload in the
	# ADARA RunInfo Packet...! ;-D
	#

	# Starting Point for New Proposal Id Substitution Line...
	ipts_new_line="${ipts_old_line}"

	# New IPTS is _Shorter_ than Old IPTS, Just Pad with White Space...
	if [[ ${#IPTS_NEW} -lt ${#ipts_old} ]]; then

		len_diff=$(( ${#ipts_old} - ${#IPTS_NEW} ))

		echo -e -n "\nNew Proposal Id [${IPTS_NEW}] is "
		echo "_Shorter_ than Old [${ipts_old}]:"
		echo -e -n "\t${#ipts_old} - ${#IPTS_NEW} = ${len_diff} "
		echo "Spaces to Pad."

		for (( i = 0 ; i < ${len_diff} ; ++i )); do
			IPTS_NEW="${IPTS_NEW} "
		done

		echo -e "\nResulting New Proposal Id is: [${IPTS_NEW}]"
	
	# New IPTS is _Longer_ than Old IPTS, Just Pad with White Space...
	elif [[ ${#IPTS_NEW} -gt ${#ipts_old} ]]; then

		len_diff=$(( ${#IPTS_NEW} - ${#ipts_old} ))

		echo -e -n "\nNew Proposal Id [${IPTS_NEW}] is "
		echo "_Longer_ than Old [${ipts_old}]:"
		echo -e -n "\t${#IPTS_NEW} - ${#ipts_old} = ${len_diff} "
		echo "Spaces to Remove from Line!"

		# Try to Remove Sufficient Spaces from Old Proposal Id Line...!

		skip_run=0

		for (( i = 0 ; i < ${len_diff} ; ++i )); do

			ckspc=`echo "${ipts_new_line}" | grep -c " "`
			if [[ "$ckspc" != "1" ]]; then
				echo -e -n "\nERROR: Insufficient White Space to Remove "
				echo "in Old Proposal Id Line!"
				CHECK_PROCEED
				echo -e "\nContinuing with Next Run Number..."
				skip_run=1
				break
			fi

			# Take Any Space We Can Get...! ;-D
			ipts_new_line=`echo "${ipts_new_line}" | sed 's/ //'`

		done

		# Skip This Run, We Had a Failure...
		if [[ $skip_run == 1 ]]; then
			continue
		fi

		echo -e "\nResulting New/Old Proposal Id Line Template is:"
		echo -e "\t[${ipts_new_line}]"

	else

		echo -e -n "\nNew Proposal Id [${IPTS_NEW}] is "
		echo "_Same_ Length as Old [${ipts_old}]:"
		echo -e "\t${#IPTS_NEW} = ${#ipts_old}"

	fi

	#
	# Now Substitute Old IPTS for New IPTS in New Proposal Id Line...
	#

	ipts_new_line=`echo "${ipts_new_line}" \
		| sed "s/${ipts_old}/${IPTS_NEW}/"`

	echo -e "\nFinal Proposal Id Line Substitution:"
	echo -e "\told: [${ipts_old_line}]"
	echo -e "\tnew: [${ipts_new_line}]"

	CHECK_PROCEED


	# Re-Name the "proposal-*" Placeholder File in the Run Directory...!

done

#
# Done
#

echo -e "\nDone.\n"


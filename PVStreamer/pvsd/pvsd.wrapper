#!/bin/bash
#
# PVSD Wrapper Script
#
# "/usr/sbin/pvsd" points to "/home/controls/config-dassrv1/deploy/pvsd",
# which points to deployed binary in "/home/controls/prod/ADARA/<tag>/pvsd".
#

exec /usr/sbin/pvsd -c /home/controls/bl999/beamline.xml --domain SNS.XXX \
	--broker_uri tcp://amqbroker.sns.gov --broker_user wfclient \
	--broker_pw w0rkfl0w --daemon


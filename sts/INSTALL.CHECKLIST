
ADARA STS Install Checklist

	- for a New or Upgraded STS1/STS2 (or Labanalysis) Host...

# NOTE: If Verifying the State of an Existing Git Config Repository,
# Please Skip Step 1.a. and Proceed to Step 1.b. :-D 

1.a. Create Initial STS Configuration on New Beamline/Host:

	# Make Top Level Home Controls Area...

	ls -ld /home/controls

	sudo mkdir /home/controls

	sudo chown controls /home/controls

	sudo chgrp slowcontrols_developers /home/controls

	sudo chmod g+ws /home/controls/

	ls -ld /home/controls

	# Create New Git Config Repo Branch, Copy/Steal from Existing Branch!

	ls -l /home/controls/config/

	git clone git+ssh://trac.sns.gov/var/repos/config \
		/home/controls/config/

	cd /home/controls/config/

	OLD="stsXXX"   # "Old" or Existing Beamline Branch to Copy From

	NEW="stsYYY"   # "New" Beamline Branch Being Created

	git checkout ${OLD}

	git branch ${NEW}

	git checkout ${NEW}

	git branch -d ${OLD}

	git branch -a | head

		* stsYYY
		  master
		  remotes/origin/HEAD -> origin/master
		  . . .

	git rm -r deploy/ sts.deployment.history.txt

	git commit -m "Clearing Deployment History from Copied Branch" \
		deploy/ sts.deployment.history.txt

	git status

	git push origin ${NEW}

	RedHat6:
	vi .git/config
		- add section:
			[branch "stsYYY"]
				remote = origin
				merge = refs/heads/stsYYY

	RedHat7:
	git branch --set-upstream-to=origin/${NEW} ${NEW}

	git push

	git status

	# Populate New Branch with Schtuff...! ;-D

	### NOTE: If Just Copied Complete Setup from Existing Branch,
	### Then Please Proceed to Step 1.b. :-D

	### Else Proceed with Step 1.a to Create Brand New Config. :-D

	# Remove Any "brdo" (BranchDo) Script Inherited from "master" Branch...

	git rm brdo
	git commit -m "Remove BranchDo Script from Master Branch" brdo

	# Get/Copy/Create a "confck" Script...

	cp /SNS/users/y8y/confck.sts confck
	git add confck
	git commit -m "Install ConfCk Script." confck

	./confck

	# STS XInetd Configurations

	mkdir -p etc/xinetd.d

	-> Do For Each ${STS} Deployment in:
		"sts", "sts_test", "sts_dummy", "sts_hfir" and "sts_hfir_test"

		sudo cp ~/gitsrc/ADARA/sts/sts.xinetd /etc/xinetd.d/${STS}

		sudo vi /etc/xinetd.d/${STS}
			- set "id" to "${STS}-stream"
			- set "server" to "/usr/local/bin/${STS}"
			- set "port" to:
				-> sts = 31417
				-> sts_test = 31418
				-> sts_dummy = 31419
				-> sts_hfir = 31420
				-> sts_hfir_test = 31421

		cp /etc/xinetd.d/${STS} etc/xinetd.d/${STS}

	# STS Services

	-> Add the Following Ports to /etc/services:

	sudo vi /etc/services

		sts             31417/udp
		sts             31417/tcp
		sts_test        31418/udp
		sts_test        31418/tcp
		sts_dummy       31419/udp
		sts_dummy       31419/tcp
		sts_hfir        31420/udp
		sts_hfir        31420/tcp
		sts_hfir_test   31421/udp
		sts_hfir_test   31421/tcp

	cp /etc/services etc/services

	git add etc
	git commit -m "STS Etc and XInetd Config Files." etc

	# STS Wrapper Scripts

	mkdir -p usr/local/bin

	-> Do For Each ${STS} Deployment in:
		"sts", "sts_test", "sts_dummy", "sts_hfir" and "sts_hfir_test"

		sudo cp ~/gitsrc/ADARA/sts/sts.wrapper /usr/local/bin/${STS}

		sudo vi /usr/local/bin/${STS}
			- set "CONFIG_FILE" to:
				-> sts = "/SNS/snfs1/stsdata/sts_config.xml"
				-> sts_test = "/SNS/snfs1/stsdata_test/sts_config.xml"
				-> sts_dummy = "/TESTING/SNS/stsdata_dummy/sts_config.xml"
				-> sts_hfir = "/HFIR/stsdata_hfir/sts_config.xml"
				-> sts_hfir_test = "/HFIR/stsdata_hfir_test/sts_config.xml"
			- set binary executable path to:
				-> sts = "/usr/sbin/sts"
				-> sts_test = "/usr/sbin/sts_test"
				-> sts_dummy = "/usr/sbin/sts_dummy"
				-> sts_hfir = "/usr/sbin/sts_hfir"
				-> sts_hfir_test = "/usr/sbin/sts_hfir_test"
			- set "STS Working Directory" (-w <path>) to:
				-> sts = "-w /SNS/snfs1/stsdata"
				-> sts_test = "-w /SNS/snfs1/stsdata_test"
				-> sts_dummy = "-w /TESTING/SNS/stsdata_dummy"
				-> sts_hfir = "-w /HFIR/HB2C/stsdata_hfir"
					NOTE: HFIR STS Deployments are Per Beamline...!
				-> sts_hfir_test = "-w /HFIR/HB2C/stsdata_hfir_test"
					NOTE: HFIR STS Deployments are Per Beamline...!

		cp /usr/local/bin/${STS} usr/local/bin/${STS}

	git add usr
	git commit -m "STS Usr Local Bin Wrapper Scripts." usr

1.b. Verify State of Existing Git Config Repository:

	pushd /home/controls/config/ ; git pull ; git diff ; git status

	./confck

	sudo cp etc/rsyslog.d/adaraMailer.conf /etc/rsyslog.d/adaraMailer.conf

	sudo cp etc/rsyslog.d/stslog.conf /etc/rsyslog.d/stslog.conf

	sudo cp etc/xinetd.d/sts /etc/xinetd.d/sts

	sudo cp etc/xinetd.d/sts_dummy /etc/xinetd.d/sts_dummy

	sudo cp etc/xinetd.d/sts_hfir /etc/xinetd.d/sts_hfir

	sudo cp etc/xinetd.d/sts_hfir_test /etc/xinetd.d/sts_hfir_test

	sudo cp etc/xinetd.d/sts_test /etc/xinetd.d/sts_test

	sudo cp usr/local/bin/sts /usr/local/bin/sts

	sudo cp usr/local/bin/sts_dummy /usr/local/bin/sts_dummy

	sudo cp usr/local/bin/sts_hfir /usr/local/bin/sts_hfir

	sudo cp usr/local/bin/sts_hfir_test /usr/local/bin/sts_hfir_test

	sudo cp usr/local/bin/sts_test /usr/local/bin/sts_test

	ls -l /etc/rsyslog.d/adaraMailer.conf /etc/rsyslog.d/stslog.conf \
		/etc/xinetd.d/sts /etc/xinetd.d/sts_dummy \
		/etc/xinetd.d/sts_hfir /etc/xinetd.d/sts_hfir_test \
		/etc/xinetd.d/sts_test \
		/usr/local/bin/sts /usr/local/bin/sts_dummy \
		/usr/local/bin/sts_hfir /usr/local/bin/sts_hfir_test \
		/usr/local/bin/sts_test


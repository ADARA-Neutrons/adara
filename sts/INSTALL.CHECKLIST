	-rwxrwxr-x 1 snsdata  adara          246 Mar 22 16:44
		/usr/local/bin/sts*
	-rwxrwxr-x 1 snsdata  adara          308 Mar 22 16:44
		/usr/local/bin/sts_dummy*
	-rwxrwxr-x 1 hfirdata adara          417 Mar 22 16:43

<sts_config>

	<version>1.0.0</version>

	<!-- Sample Meta-Data Group -->
	<group>
		<name>sample</name>
		<path>/entry</path>
		<type>NXsample</type>
		<element>
			<pattern>SMS:RunInfo:Sample:Id</pattern>
			<name>identifier</name>
		</element>
		<element>
			<pattern>SMS:RunInfo:Sample:Name</pattern>
			<name>name</name>
		</element>
		<element>
			<pattern>SMS:RunInfo:Sample:Nature</pattern>
			<name>nature</name>
		</element>
		<element>
			<pattern>SMS:RunInfo:Sample:Formula</pattern>
			<name>chemical_formula</name>
		</element>
		<element>
			<pattern>SMS:RunInfo:Sample:Mass$</pattern>
			<name>mass</name>
			<units_value>SMS:RunInfo:Sample:MassUnits</units_value>
		</element>
		<element>
			<pattern>SMS:RunInfo:Sample:Density$</pattern>
			<name>mass_density</name>
			<units_value>SMS:RunInfo:Sample:DensityUnits</units_value>
		</element>
		<!-- Need to Concatenate These Two, with a ":" for "component"! -->
		<element>
			<pattern>SMS:RunInfo:Sample:ContainerId</pattern>
			<name>container_id</name>
		</element>
		<element>
			<pattern>SMS:RunInfo:Sample:ContainerName</pattern>
			<name>container_name</name>
		</element>
		<element>
			<pattern>SMS:RunInfo:Sample:CanIndicator</pattern>
			<name>can_indicator</name>
		</element>
		<element>
			<pattern>SMS:RunInfo:Sample:CanBarcode</pattern>
			<name>can_barcode</name>
		</element>
		<element>
			<pattern>SMS:RunInfo:Sample:CanName</pattern>
			<name>can_name</name>
		</element>
		<element>
			<pattern>SMS:RunInfo:Sample:CanMaterials</pattern>
			<name>can_materials</name>
		</element>
		<element>
			<pattern>SMS:RunInfo:Sample:Description</pattern>
			<name>description</name>
		</element>
		<element>
			<pattern>SMS:RunInfo:Sample:Comments</pattern>
			<name>comments</name>
		</element>
		<element>
			<pattern>SMS:RunInfo:Sample:HeightInContainer$</pattern>
			<name>height_in_container</name>
			<units_value>SMS:RunInfo:Sample:HeightInContainerUnits</units_value>
		</element>
		<element>
			<pattern>SMS:RunInfo:Sample:InteriorDiameter$</pattern>
			<name>interior_diameter</name>
			<units_value>SMS:RunInfo:Sample:InteriorDiameterUnits</units_value>
		</element>
		<element>
			<pattern>SMS:RunInfo:Sample:InteriorHeight$</pattern>
			<name>interior_height</name>
			<units_value>SMS:RunInfo:Sample:InteriorHeightUnits</units_value>
		</element>
		<element>
			<pattern>SMS:RunInfo:Sample:InteriorWidth$</pattern>
			<name>interior_width</name>
			<units_value>SMS:RunInfo:Sample:InteriorWidthUnits</units_value>
		</element>
		<element>
			<pattern>SMS:RunInfo:Sample:InteriorDepth$</pattern>
			<name>interior_depth</name>
			<units_value>SMS:RunInfo:Sample:InteriorDepthUnits</units_value>
		</element>
		<element>
			<pattern>SMS:RunInfo:Sample:OuterDiameter$</pattern>
			<name>outer_diameter</name>
			<units_value>SMS:RunInfo:Sample:OuterDiameterUnits</units_value>
		</element>
		<element>
			<pattern>SMS:RunInfo:Sample:OuterHeight$</pattern>
			<name>outer_height</name>
			<units_value>SMS:RunInfo:Sample:OuterHeightUnits</units_value>
		</element>
		<element>
			<pattern>SMS:RunInfo:Sample:OuterWidth$</pattern>
			<name>outer_width</name>
			<units_value>SMS:RunInfo:Sample:OuterWidthUnits</units_value>
		</element>
		<element>
			<pattern>SMS:RunInfo:Sample:OuterDepth$</pattern>
			<name>outer_depth</name>
			<units_value>SMS:RunInfo:Sample:OuterDepthUnits</units_value>
		</element>
		<element>
			<pattern>SMS:RunInfo:Sample:VolumeCubic$</pattern>
			<name>volume_cubic</name>
			<units_value>SMS:RunInfo:Sample:VolumeCubicUnits</units_value>
		</element>
	</group>

	<!-- (Indexed) Chopper Groups -->
	<group>
		<name>chopper[XXX_INDEX_XXX]</name>
		<path>/entry/instrument</path>
		<type>NXdisk_chopper</type>
		<!-- EPICS-based Chopper PV Elements -->
		<element>
			<pattern>:Chop:Skf\d+:DriveError</pattern>
			<index>%*[^:]:Chop:Skf%d:DriveError</index>
			<name>drive_error</name>
		</element>
		<element>
			<pattern>:Chop:Skf\d+:MotorSpeed</pattern>
			<index>%*[^:]:Chop:Skf%d:MotorSpeed</index>
			<pattern>Speed\d+</pattern>
			<index>Speed%d</index>
			<name>rotation_speed</name>
		</element>
		<element>
			<pattern>:Chop:Skf\d+:PhaseAccuracy</pattern>
			<index>%*[^:]:Chop:Skf%d:PhaseAccuracy</index>
			<pattern>Phase\d+</pattern>
			<index>Phase%d</index>
			<name>phase</name>
		</element>
		<element>
			<pattern>:Chop:Skf\d+:PhaseLocked</pattern>
			<index>%*[^:]:Chop:Skf%d:PhaseLocked</index>
			<name>phase_locked</name>
		</element>
		<element>
			<pattern>:Chop:Skf\d+:SpeedSet</pattern>
			<index>%*[^:]:Chop:Skf%d:SpeedSet</index>
			<name>speed_set</name>
		</element>
		<element>
			<pattern>:Chop:Skf\d+:SpeedUserReq</pattern>
			<index>%*[^:]:Chop:Skf%d:SpeedUserReq</index>
			<pattern>SpeedRequest\d+</pattern>
			<index>SpeedRequest%d</index>
			<name>speed_request</name>
		</element>
		<!-- Chopper Element Aliases (and Legacy for ADARA Test Harness) -->
		<element>
			<pattern>ChopperStatus\d+</pattern>
			<index>ChopperStatus%d</index>
			<name>status</name>
		</element>
		<element>
			<pattern>PhaseRequest\d+</pattern>
			<index>PhaseRequest%d</index>
			<name>phase_request</name>
		</element>
	</group>

	<!-- Focus Array Group (HYSPEC) -->
	<group>
		<name>focus_array</name>
		<path>/entry/instrument</path>
		<type>NXcrystal</type>
		<!-- EPICS-based Focus Array PV Elements -->
		<element>
			<pattern>:Mot:vmel:Position</pattern>
			<name>position</name>
		</element>
		<!-- "PG" Mode Conditional Focus Array PV Elements -->
		<condition>
			<name>PG Position Condition</name>
			<pattern>:Mot:vmel:Position</pattern>
			<value_string>PG</value_string><!-- 1 -->
			<element>
				<pattern>:Mot:mfpg$</pattern>
				<name>mf</name>
			</element>
			<element>
				<pattern>:Mot:mgpg$</pattern>
				<name>mg</name>
			</element>
			<element>
				<pattern>:Mot:mtpg$</pattern>
				<name>mt</name>
			</element>
			<element>
				<pattern>:Mot:m1pg$</pattern>
				<name>m1</name>
			</element>
		</condition>
		<!-- "HU" Mode Conditional Focus Array PV Elements -->
		<condition>
			<name>HU Position Condition</name>
			<pattern>:Mot:vmel:Position</pattern>
			<value>0</value><!-- HU -->
			<value>2</value><!-- HU -->
			<!-- or we could do a "not_value" tag of "1" here... -->
			<element>
				<pattern>:Mot:mfhu$</pattern>
				<name>mf</name>
			</element>
			<element>
				<pattern>:Mot:mghu$</pattern>
				<name>mg</name>
			</element>
			<element>
				<pattern>:Mot:mthu$</pattern>
				<name>mt</name>
			</element>
			<element>
				<pattern>:Mot:m1hu$</pattern>
				<name>m1</name>
			</element>
		</condition>
	</group>

</sts_config>


<sts_config>

	<version>0.1.0</version>

	<!-- EPICS-based Chopper Groups -->
	<group>
		<name>chopper1</name>
		<path>/entry/instrument</path>
		<type>NXdisk_chopper</type>
		<element>
			<pattern>:Chop:Skf1:DriveError</pattern>
			<name>drive_error</name>
			<type>NXlog</type>
		</element>
		<element>
			<pattern>:Chop:Skf1:MotorSpeed</pattern>
			<name>rotation_speed</name>
			<type>NXlog</type>
		</element>
		<element>
			<pattern>:Chop:Skf1:PhaseAccuracy</pattern>
			<name>phase</name>
			<type>NXlog</type>
		</element>
		<element>
			<pattern>:Chop:Skf1:PhaseLocked</pattern>
			<name>phase_locked</name>
			<type>NXlog</type>
		</element>
		<element>
			<pattern>:Chop:Skf1:SpeedSet</pattern>
			<name>speed_set</name>
			<type>NXlog</type>
		</element>
		<element>
			<pattern>:Chop:Skf1:SpeedUserReq</pattern>
			<name>speed_user_request</name>
			<type>NXlog</type>
		</element>
	</group>

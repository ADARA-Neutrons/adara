<sts_config>

	<version>0.1.1</version>

	<!-- Chopper Groups -->
	<group>
		<name>chopper1</name>
		<path>/entry/instrument</path>
		<type>NXdisk_chopper</type>
		<!-- EPICS-based Chopper PV Elements -->
		<element>
			<pattern>:Chop:Skf1:DriveError</pattern>
			<name>drive_error</name>
		</element>
		<element>
			<pattern>:Chop:Skf1:MotorSpeed</pattern>
			<pattern>Speed1</pattern>
			<name>rotation_speed</name>
		</element>
		<element>
			<pattern>:Chop:Skf1:PhaseAccuracy</pattern>
			<pattern>Phase1</pattern>
			<name>phase</name>
		</element>
		<element>
			<pattern>:Chop:Skf1:PhaseLocked</pattern>
			<name>phase_locked</name>
		</element>
		<element>
			<pattern>:Chop:Skf1:SpeedSet</pattern>
			<name>speed_set</name>
		</element>
		<element>
			<pattern>:Chop:Skf1:SpeedUserReq</pattern>
			<pattern>SpeedRequest1</pattern>
			<name>speed_request</name>
		</element>
		<!-- Chopper Element Aliases (and Legacy for ADARA Test Harness) -->
		<element>
			<pattern>ChopperStatus1</pattern>
			<name>status</name>
		</element>
		<element>
			<pattern>PhaseRequest1</pattern>
			<name>phase_request</name>
		</element>
	</group>
	<group>
		<name>chopper2</name>
		<path>/entry/instrument</path>
		<type>NXdisk_chopper</type>
		<!-- EPICS-based Chopper PV Elements -->
		<element>
			<pattern>:Chop:Skf2:DriveError</pattern>
			<name>drive_error</name>
		</element>
		<element>
			<pattern>:Chop:Skf2:MotorSpeed</pattern>
			<pattern>Speed2</pattern>
			<name>rotation_speed</name>
		</element>
		<element>
			<pattern>:Chop:Skf2:PhaseAccuracy</pattern>
			<pattern>Phase2</pattern>
			<name>phase</name>
		</element>
		<element>
			<pattern>:Chop:Skf2:PhaseLocked</pattern>
			<name>phase_locked</name>
		</element>
		<element>
			<pattern>:Chop:Skf2:SpeedSet</pattern>
			<name>speed_set</name>
		</element>
		<element>
			<pattern>:Chop:Skf2:SpeedUserReq</pattern>
			<pattern>SpeedRequest2</pattern>
			<name>speed_request</name>
		</element>
		<!-- Chopper Element Aliases (and Legacy for ADARA Test Harness) -->
		<element>
			<pattern>ChopperStatus2</pattern>
			<name>status</name>
		</element>
		<element>
			<pattern>PhaseRequest2</pattern>
			<name>phase_request</name>
		</element>
	</group>
	<group>
		<name>chopper3</name>
		<path>/entry/instrument</path>
		<type>NXdisk_chopper</type>
		<!-- EPICS-based Chopper PV Elements -->
		<element>
			<pattern>:Chop:Skf3:DriveError</pattern>
			<name>drive_error</name>
		</element>
		<element>
			<pattern>:Chop:Skf3:MotorSpeed</pattern>
			<pattern>Speed3</pattern>
			<name>rotation_speed</name>
		</element>
		<element>
			<pattern>:Chop:Skf3:PhaseAccuracy</pattern>
			<pattern>Phase3</pattern>
			<name>phase</name>
		</element>
		<element>
			<pattern>:Chop:Skf3:PhaseLocked</pattern>
			<name>phase_locked</name>
		</element>
		<element>
			<pattern>:Chop:Skf3:SpeedSet</pattern>
			<name>speed_set</name>
		</element>
		<element>
			<pattern>:Chop:Skf3:SpeedUserReq</pattern>
			<pattern>SpeedRequest3</pattern>
			<name>speed_request</name>
		</element>
		<!-- Chopper Element Aliases (and Legacy for ADARA Test Harness) -->
		<element>
			<pattern>ChopperStatus3</pattern>
			<name>status</name>
		</element>
		<element>
			<pattern>PhaseRequest3</pattern>
			<name>phase_request</name>
		</element>
	</group>

	<!-- Focus Array Group (HYSPEC) -->
	<group>
		<name>focus_array</name>
		<path>/entry/instrument</path>
		<type>NXcrystal</type>
		<!-- EPICS-based Focus Array PV Elements -->
		<element>
			<pattern>:Mot:vmel:Position</pattern>
			<name>position</name>
		</element>
		<!-- "PG" Mode Conditional Focus Array PV Elements -->
		<condition>
			<name>PG Position Condition</name>
			<pattern>:Mot:vmel:Position</pattern>
			<value_string>PG</value_string><!-- 1 -->
			<element>
				<pattern>:Mot:mfpg</pattern>
				<name>mfpg</name>
			</element>
			<element>
				<pattern>:Mot:mgpg</pattern>
				<name>mgpg</name>
			</element>
			<element>
				<pattern>:Mot:mtpg</pattern>
				<name>mtpg</name>
			</element>
			<element>
				<pattern>:Mot:m1pg</pattern>
				<name>m1pg</name>
			</element>
		</condition>
		<!-- "HU" Mode Conditional Focus Array PV Elements -->
		<condition>
			<name>HU Position Condition</name>
			<pattern>:Mot:vmel:Position</pattern>
			<value>0</value><!-- HU -->
			<value>2</value><!-- HU -->
			<!-- or we could do a "not_value" tag of "1" here... -->
			<element>
				<pattern>:Mot:mfhu</pattern>
				<name>mfhu</name>
			</element>
			<element>
				<pattern>:Mot:mghu</pattern>
				<name>mghu</name>
			</element>
			<element>
				<pattern>:Mot:mthu</pattern>
				<name>mthu</name>
			</element>
			<element>
				<pattern>:Mot:m1hu</pattern>
				<name>m1hu</name>
			</element>
		</condition>
	</group>

</sts_config>

